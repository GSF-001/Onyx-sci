NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://user:password@localhost:5432/research_copilot

JWT_ACCESS_SECRET=ganti-dengan-random-string-minimal-32-karakter
JWT_REFRESH_SECRET=ganti-dengan-random-string-lain-minimal-32-karakter
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=30

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Research Copilot <no-reply@researchcopilot.app>"

APP_URL=http://localhost:3000
COOKIE_DOMAIN=localhost
