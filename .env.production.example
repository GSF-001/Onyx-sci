# Production Environment Variables

# Node
NODE_ENV=production
PORT=3000

# Database - Use managed PostgreSQL (AWS RDS, Supabase, etc)
DATABASE_URL=postgresql://user:password@prod-db.example.com:5432/onyx_prod

# Clerk Authentication
CLERK_PUBLISHABLE_KEY=pk_live_your_production_key
CLERK_SECRET_KEY=sk_live_your_production_key
CLERK_PROXY_URL=https://your-domain.com/api/auth/proxy

# AI Services - Production Keys
GROQ_API_KEY=your_production_groq_key
OPENAI_API_KEY=your_production_openai_key

# Error Tracking
SENTRY_DSN=https://key@sentry.io/production-project
SENTRY_ENVIRONMENT=production

# Frontend
VITE_CLERK_PUBLISHABLE_KEY=pk_live_your_production_key
VITE_CLERK_PROXY_URL=https://your-domain.com/api/auth/proxy
VITE_API_URL=https://api.your-domain.com
VITE_SENTRY_DSN=https://key@sentry.io/frontend-project

# Logging
LOG_LEVEL=warn

# Redis (optional, for caching)
REDIS_URL=redis://prod-redis:6379

# Email Service (optional, for notifications)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key

# Storage (optional, for file uploads)
S3_BUCKET=onyx-prod-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_aws_access_key
S3_SECRET_ACCESS_KEY=your_aws_secret_key
